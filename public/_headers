/assets/*
  Cache-Control: public, max-age=31536000, immutable

# SPA navigation documents are served the index.html shell. They must always
# revalidate so a returning client never boots from pre-deploy HTML that points
# at hashed chunks which no longer exist (blank screen / MIME text/html error).
/index.html
  Cache-Control: no-cache

/
  Cache-Control: no-cache

/app/*
  Cache-Control: no-cache

/*
  X-Content-Type-Options: nosniff