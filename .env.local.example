# Copy to .env.local for local development.
# .env.local is gitignored — safe to put dev-only values here.

# Override Vite dev proxy to point to local backend instead of production.
# Default (when unset): https://finotaur-server-production.up.railway.app
# Local backend: http://localhost:3000 (or whatever port your backend uses)
# VITE_PROXY_TARGET=http://localhost:3000

# ─── Analytics (Stage 1B — Google Analytics 4) ───────────────────────────────
# Format: G-XXXXXXXXXX  (find in GA4 Admin → Data Streams → Web stream details)
# Leave unset to disable GA4 silently (no error, no network call).
# VITE_GA4_MEASUREMENT_ID=G-XXXXXXXXXX

# ─── Analytics (Stage 1C — PostHog) ──────────────────────────────────────────
# phc_... key from PostHog Project Settings → Project API key.
# Leave unset to disable PostHog silently (no error, no network call).
# VITE_POSTHOG_KEY=phc_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
# US data residency (default):
# VITE_POSTHOG_HOST=https://us.i.posthog.com
# EU data residency (GDPR):
# VITE_POSTHOG_HOST=https://eu.i.posthog.com
